# ============================================================== fund-wide ===
# Logical bankroll for the ledger-managed sleeves (polymarket + sportsbook).
FUND_BANKROLL=10000
# Comma-separated sleeves to run. Each disables itself if its key is missing.
SLEEVES=markets,polymarket,sportsbook,insiders
ALLOC_MARKETS=0.50
ALLOC_POLYMARKET=0.30
ALLOC_SPORTSBOOK=0.20

# Risk (fractions of equity)
KELLY_FRACTION=0.25
MAX_STAKE_PCT=0.02
DAILY_LOSS_LIMIT=0.03
MAX_DRAWDOWN=0.15

# ----- going live (real money) -----
# FUND_LIVE=1 makes the fund trade real money everywhere it can:
#   - markets + insiders: Alpaca LIVE endpoint (use live keys, funded account)
#   - polymarket: real FOK orders if POLYMARKET_PRIVATE_KEY is set
# Run `python run.py --live-check` first. Start small.
#FUND_LIVE=1

# Hard dollar ceiling per position in live mode, on top of all % caps:
MAX_LIVE_STAKE_USD=250

# Polymarket wallet (Polygon). Private key controls real funds — env only.
# Deposited via the Polymarket site? Set POLYMARKET_FUNDER to your proxy
# wallet address and signature type 1 (email login) / 2 (browser wallet).
# Direct EOA wallet: leave funder empty, signature type 0.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER=
POLYMARKET_SIGNATURE_TYPE=0

# Optional Slack/Discord incoming webhook for 7am/9pm reports
REPORT_WEBHOOK_URL=

# ======================================================== markets (Alpaca) ===
# Free paper keys at https://alpaca.markets
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ============================================================= polymarket ===
# No API key needed (public data). Pin extra wallets to follow:
PM_FOLLOW_WALLETS=
PM_TOP_N=50
PM_MIN_PNL=25000
PM_MAX_FOLLOWED=8
PM_MIN_LEADER_TRADE_USD=500

# =============================================================== insiders ===
# Executes through the same Alpaca account as the markets sleeve.
# Congressional trades: Quiver key is the best source (api.quiverquant.com);
# without it the sleeve tries Capitol Trades' public endpoint.
QUIVER_API_KEY=
# SEC requires a contact in the User-Agent for EDGAR requests:
EDGAR_USER_AGENT=fund-bot your-email@example.com
# Empty = copy every filer above the floor; or restrict (e.g. pelosi,tuberville)
INS_FOLLOW_POLITICIANS=
INS_MIN_TRADE_USD=15000
# Emphasis ("Trump factor"): name matches and tickers that get 2x stake.
# "trump" is always included; add allies here:
INS_EMPHASIS_NAMES=
INS_EMPHASIS_TICKERS=DJT
INS_EMPHASIS_MULT=2.0

# Form 3/4 parroting: personal SEC-disclosed trades of named insiders,
# public within 2 business days. Donald J. Trump (947033) and Donald
# Trump Jr. (2016181) are followed by default; add more as Name:CIK pairs:
#INS_FORM4_FILERS=Eric Trump:0001234567
INS_FORM4_POLL_HOURS=1
INS_FORM4_WEIGHT=1.0
# First run only trades filings newer than this; older history is snapshotted
INS_FORM4_BOOTSTRAP_DAYS=14

# ============================================================= sportsbook ===
# Same key as the TS platform (https://the-odds-api.com)
THE_ODDS_API_KEY=
SB_SPORTS=basketball_nba,baseball_mlb,icehockey_nhl,soccer_epl
SB_REGIONS=us,eu
SB_MIN_EV=0.03
